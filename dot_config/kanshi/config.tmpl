{{- $machine := output "cat" "/sys/class/dmi/id/product_family" | trim -}}

{{- /* Output aliases */ -}}
{{- $DELL := "Dell Inc. DELL P3223QE FGS34P3" -}}
{{- $dellModeW := 3840 -}}
{{- $dellModeH := 2160 -}}
{{- $dellScale := 1.25 -}}
{{- $dellLogicalW := divf (float64 $dellModeW) $dellScale | int -}}
{{- $dellLogicalH := divf (float64 $dellModeH) $dellScale | int -}}

{{- $LENOVO_L := "Lenovo Group Limited P32p-30 V30F61YW" -}}
{{- $LENOVO_R := "Lenovo Group Limited P32p-30 V30F61Y7" -}}
{{- $lenovoModeW := 3840 -}}
{{- $lenovoModeH := 2160 -}}
{{- $lenovoScale := 1.25 -}}
{{- $lenovoLogicalW := divf (float64 $lenovoModeW) $lenovoScale | int -}}
{{- $lenovoLogicalH := divf (float64 $lenovoModeH) $lenovoScale | int -}}

{{- $INTERNAL := "" -}}
{{- $internalModeW := 0 -}}
{{- $internalModeH := 0 -}}
{{- $internalScale := 1.0 -}}

{{- if eq $machine "ThinkPad P14s Gen 5 AMD" -}}
{{-   $INTERNAL = "Lenovo Group Limited 0x414B Unknown" -}}
{{-   $internalModeW = 2880 -}}
{{-   $internalModeH = 1800 -}}
{{-   $internalScale = 1.75 -}}
{{- else if eq $machine "ThinkPad X1 Carbon Gen 12" -}}
{{-   $INTERNAL = "Unknown Unknown Unknown" -}}
{{-   $internalModeW = 1920 -}}
{{-   $internalModeH = 1200 -}}
{{-   $internalScale = 1.25 -}}
{{- end -}}

{{- $internalLogicalH := divf (float64 $internalModeH) $internalScale | int -}}
{{- $dualX := $dellLogicalW -}}
{{- $dualY := sub $dellLogicalH $internalLogicalH }}

# kanshi output profiles — {{ $machine }}

# Laptop display only
profile {
    output "{{ $INTERNAL }}" mode {{ $internalModeW }}x{{ $internalModeH }} scale {{ $internalScale }}
}

# Laptop + DELL P3223QE (main center, laptop bottom-right)
profile {
    output "{{ $DELL }}" mode {{ $dellModeW }}x{{ $dellModeH }} position 0,0 scale {{ $dellScale }}
    output "{{ $INTERNAL }}" mode {{ $internalModeW }}x{{ $internalModeH }} position {{ $dualX }},{{ $dualY }} scale {{ $internalScale }}
}

# Office: dual Lenovo P32p-30 + laptop (left primary, right beside, laptop below-left)
profile {
    output "{{ $LENOVO_L }}" mode {{ $lenovoModeW }}x{{ $lenovoModeH }} position 0,0 scale {{ $lenovoScale }}
    output "{{ $LENOVO_R }}" mode {{ $lenovoModeW }}x{{ $lenovoModeH }} position {{ $lenovoLogicalW }},0 scale {{ $lenovoScale }}
    output "{{ $INTERNAL }}" mode {{ $internalModeW }}x{{ $internalModeH }} position 0,{{ $lenovoLogicalH }} scale {{ $internalScale }}
}
