// niri config
// $mod = Alt, movement keys: r=left, n=down, t=up, s=right (3l layout)

environment {
    BROWSER "google-chrome-stable"
}

input {
    keyboard {
        xkb {
            layout "us"
            variant "3l"
        }
        repeat-delay 300
        repeat-rate 50
    }

    touchpad {
        tap
        dwt  // disable while typing
    }

    focus-follows-mouse


}

// --------------------------------------------------------------------------
// Layout & Appearance
// --------------------------------------------------------------------------

layout {
    gaps 0

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    default-column-display "tabbed"
    always-center-single-column
    default-column-width { proportion 1.0; }

    focus-ring {
        off
    }

    border {
        off
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=6
        color "#00000066"
    }

    tab-indicator {
        hide-when-single-tab
        place-within-column
        gap 0
        width 4
        length total-proportion=1.0
        position "top"
        gaps-between-tabs 0
        corner-radius 0
        active-color "#ffffffff"
        inactive-color "#666666ff"
        urgent-color "#ffffffff"
    }

    insert-hint {
        color "#ffffff66"
    }

}

// prefer-no-csd

workspace "ws1"
workspace "ws2"
workspace "ws3"
workspace "ws4"
workspace "ws5"
workspace "ws6"
workspace "ws7"
workspace "ws8"
workspace "ws9"
workspace "ws10"

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// --------------------------------------------------------------------------
// Startup
// --------------------------------------------------------------------------

spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "swaybg" "-i" "${HOME}/.local/assets/NovoBlaze2Blur.jpg" "-m" "fill"
spawn-at-startup "flameshot"
spawn-at-startup "nm-applet"
spawn-at-startup "blueman-applet"
// Start on the first named workspace.
spawn-at-startup "sh" "-c" "sleep 1; niri msg action focus-workspace ws1"
// Polkit authentication agent — needed for GUI privilege prompts (drives, VPNs, etc.)
spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
// Clipboard history daemon
spawn-at-startup "sh" "-c" "wl-paste --watch cliphist store"
// Auto-lock: idle 5min → lock, 10min → monitors off
spawn-at-startup "sh" "-c" "swayidle -w timeout 300 '${HOME}/.local/bin/swaylock-toasters' timeout 600 'niri msg action power-off-monitors' before-sleep '${HOME}/.local/bin/swaylock-toasters' lock '${HOME}/.local/bin/swaylock-toasters'"

// --------------------------------------------------------------------------
// Window rules
// --------------------------------------------------------------------------

window-rule {
    match is-floating=false
    geometry-corner-radius 0
    clip-to-geometry true
}

window-rule {
    match app-id=r#"^com\.mitchellh\.ghostty$"# is-floating=false
    tiled-state true
    geometry-corner-radius 0
    clip-to-geometry true
}

window-rule {
    match is-floating=true
    geometry-corner-radius 8
    clip-to-geometry true
}

window-rule {
    match is-active=false
    opacity 0.92
}

// --------------------------------------------------------------------------
// Key bindings
// --------------------------------------------------------------------------

binds {
    // --- Applications ---
    Alt+Tab    { spawn "ghostty"; }
    Alt+Return { spawn "fuzzel"; }
    Alt+o      { spawn "sh" "-c" "${BROWSER}"; }
    Alt+d      { spawn "bemoji"; }
    Alt+c      { spawn "sh" "-c" "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy"; }
    Alt+p      { spawn "flameshot" "gui"; }

    // --- Window management ---
    Alt+Shift+q { close-window; }
    Alt+f       { fullscreen-window; }
    Alt+i       { toggle-window-floating; }

    // --- Focus (3l: r=left, n=down, t=up, s=right) ---
    Alt+r { focus-column-left; }
    Alt+s { focus-column-right; }
    Alt+t { focus-window-up; }
    Alt+n { focus-window-down; }

    Alt+Left  { focus-column-left; }
    Alt+Right { focus-column-right; }
    Alt+Up    { focus-window-up; }
    Alt+Down  { focus-window-down; }

    // --- Move windows ---
    Alt+Shift+r { move-column-left; }
    Alt+Shift+s { move-column-right; }
    Alt+Shift+t { move-window-up; }
    Alt+Shift+n { move-window-down; }

    Alt+Shift+Left  { move-column-left; }
    Alt+Shift+Right { move-column-right; }
    Alt+Shift+Up    { move-window-up; }
    Alt+Shift+Down  { move-window-down; }

    // --- Move column to adjacent monitor ---
    Alt+Ctrl+Shift+Right { move-column-to-monitor-right; }
    Alt+Ctrl+Shift+Left  { move-column-to-monitor-left; }

    // --- Resize: cycle preset widths, or fine-tune ---
    Alt+j       { switch-preset-column-width; }
    Alt+Shift+j { reset-window-height; }
    Alt+Ctrl+r  { set-column-width "-5%"; }
    Alt+Ctrl+s  { set-column-width "+5%"; }
    Alt+Ctrl+t  { set-window-height "-5%"; }
    Alt+Ctrl+n  { set-window-height "+5%"; }

    // --- Workspaces ---
    Alt+1 { focus-workspace "ws1"; }
    Alt+2 { focus-workspace "ws2"; }
    Alt+3 { focus-workspace "ws3"; }
    Alt+4 { focus-workspace "ws4"; }
    Alt+5 { focus-workspace "ws5"; }
    Alt+6 { focus-workspace "ws6"; }
    Alt+7 { focus-workspace "ws7"; }
    Alt+8 { focus-workspace "ws8"; }
    Alt+9 { focus-workspace "ws9"; }
    Alt+0 { focus-workspace "ws10"; }

    Alt+Shift+1 { move-window-to-workspace "ws1"; }
    Alt+Shift+2 { move-window-to-workspace "ws2"; }
    Alt+Shift+3 { move-window-to-workspace "ws3"; }
    Alt+Shift+4 { move-window-to-workspace "ws4"; }
    Alt+Shift+5 { move-window-to-workspace "ws5"; }
    Alt+Shift+6 { move-window-to-workspace "ws6"; }
    Alt+Shift+7 { move-window-to-workspace "ws7"; }
    Alt+Shift+8 { move-window-to-workspace "ws8"; }
    Alt+Shift+9 { move-window-to-workspace "ws9"; }
    Alt+Shift+0 { move-window-to-workspace "ws10"; }

    // --- Session ---
    Alt+l            { spawn "${HOME}/.local/bin/swaylock-toasters"; }
    Alt+Shift+l      { spawn "${HOME}/.local/bin/toggle-autolock.sh"; }

    Alt+Shift+period { quit; }

    // --- Screenshots ---
    Print      { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print  { screenshot-window; }

    // --- Brightness ---
    XF86MonBrightnessUp   { spawn "brightnessctl" "set" "10%+"; }
    XF86MonBrightnessDown { spawn "brightnessctl" "set" "10%-"; }

    // --- Volume ---
    XF86AudioRaiseVolume { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute        { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    Alt+F10 { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    Alt+F9  { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    Alt+F8  { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
}
