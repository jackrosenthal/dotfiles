# sway config
# $mod = Alt, movement keys: r=left, n=down, t=up, s=right (3l layout)

set $mod Mod1

# ─── Environment ──────────────────────────────────────────────────────────────

set $BROWSER google-chrome-stable

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway DISPLAY

# ─── Input ────────────────────────────────────────────────────────────────────

input type:keyboard {
    xkb_layout us
    xkb_variant 3l
    repeat_delay 300
    repeat_rate 50
}

input type:touchpad {
    tap enabled
    dwt enabled
}

focus_follows_mouse yes
floating_modifier $mod normal

# ─── Appearance ───────────────────────────────────────────────────────────────

font pango:JetBrains Mono Nerd Font 11
titlebar_padding 4 1

gaps inner 0
gaps outer 0
default_border none
default_floating_border normal 2
# border background text indicator child_border
client.focused          #2a1f35 #2a1f35 #da6bab #dd00ff #2a1f35
client.focused_inactive #1f1626 #1f1626 #666666 #1f1626 #1f1626
client.unfocused        #1f1626 #1f1626 #666666 #1f1626 #1f1626

mouse_warping container

# Rounded corners on floating windows are not natively supported in stock sway.
# Inactive window opacity (0.92) requires an external script; skipped here.

# ─── Output / Wallpaper ───────────────────────────────────────────────────────

output * bg ${HOME}/.local/assets/NovoBlaze2Blur.jpg fill

# ─── Layout ───────────────────────────────────────────────────────────────────

workspace_layout tabbed

# ─── Startup ──────────────────────────────────────────────────────────────────

exec_always kanshi
exec waybar
exec mako
exec flameshot
exec nm-applet
exec blueman-applet
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec wl-paste --watch cliphist store
# Auto-lock: idle 5min → lock, 10min → monitors off
exec swayidle -w \
    timeout 300 '${HOME}/.local/bin/swaylock-toasters' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep '${HOME}/.local/bin/swaylock-toasters' \
    lock '${HOME}/.local/bin/swaylock-toasters'

# ─── Window Rules ─────────────────────────────────────────────────────────────

for_window [app_id="com.mitchellh.ghostty" tiling] border none
for_window [floating]                       move position center

# ─── Key Bindings ─────────────────────────────────────────────────────────────

# --- Applications ---
bindsym $mod+Tab        exec ghostty
bindsym $mod+Return     exec fuzzel
bindsym $mod+o          exec $BROWSER
bindsym $mod+d          exec bemoji
bindsym $mod+c          exec sh -c 'cliphist list | fuzzel --dmenu | cliphist decode | wl-copy'
bindsym $mod+p          exec flameshot gui

# --- Window management ---
bindsym $mod+Shift+q    kill
bindsym $mod+f          fullscreen toggle
bindsym $mod+i          floating toggle

# --- Focus (3l: r=left, n=down, t=up, s=right) ---
bindsym $mod+r          focus left
bindsym $mod+s          focus right
bindsym $mod+t          focus up
bindsym $mod+n          focus down

bindsym $mod+Left       focus left
bindsym $mod+Right      focus right
bindsym $mod+Up         focus up
bindsym $mod+Down       focus down

# --- Move windows ---
bindsym $mod+Shift+r    move left
bindsym $mod+Shift+s    move right
bindsym $mod+Shift+t    move up
bindsym $mod+Shift+n    move down

bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Down  move down

# --- Move container to adjacent output ---
bindsym $mod+Ctrl+Shift+Right move container to output right; focus output right
bindsym $mod+Ctrl+Shift+Left  move container to output left;  focus output left

# --- Layout ---
bindsym $mod+a          layout toggle split   # switch to tiling (cycles h/v split)
bindsym $mod+e          layout stacking
bindsym $mod+u          split h
bindsym $mod+y          split v
bindsym $mod+q          focus mode_toggle     # toggle focus tiling/floating

# --- Scratchpad (sandbox window) ---
bindsym $mod+Shift+k    move scratchpad
bindsym $mod+k          scratchpad show

# --- Resize mode ---
mode "resize" {
    bindsym r           resize shrink width  10 px or 10 ppt
    bindsym s           resize grow   width  10 px or 10 ppt
    bindsym t           resize shrink height 10 px or 10 ppt
    bindsym n           resize grow   height 10 px or 10 ppt

    bindsym Left        resize shrink width  10 px or 10 ppt
    bindsym Right       resize grow   width  10 px or 10 ppt
    bindsym Up          resize shrink height 10 px or 10 ppt
    bindsym Down        resize grow   height 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+j          mode "resize"

# --- Fine resize (outside resize mode) ---
bindsym $mod+Ctrl+r     resize shrink width  5 ppt
bindsym $mod+Ctrl+s     resize grow   width  5 ppt
bindsym $mod+Ctrl+t     resize shrink height 5 ppt
bindsym $mod+Ctrl+n     resize grow   height 5 ppt

# --- Workspaces ---
bindsym $mod+1          workspace number 1
bindsym $mod+2          workspace number 2
bindsym $mod+3          workspace number 3
bindsym $mod+4          workspace number 4
bindsym $mod+5          workspace number 5
bindsym $mod+6          workspace number 6
bindsym $mod+7          workspace number 7
bindsym $mod+8          workspace number 8
bindsym $mod+9          workspace number 9
bindsym $mod+0          workspace number 10

bindsym $mod+Shift+1    move container to workspace number 1;  workspace number 1
bindsym $mod+Shift+2    move container to workspace number 2;  workspace number 2
bindsym $mod+Shift+3    move container to workspace number 3;  workspace number 3
bindsym $mod+Shift+4    move container to workspace number 4;  workspace number 4
bindsym $mod+Shift+5    move container to workspace number 5;  workspace number 5
bindsym $mod+Shift+6    move container to workspace number 6;  workspace number 6
bindsym $mod+Shift+7    move container to workspace number 7;  workspace number 7
bindsym $mod+Shift+8    move container to workspace number 8;  workspace number 8
bindsym $mod+Shift+9    move container to workspace number 9;  workspace number 9
bindsym $mod+Shift+0    move container to workspace number 10; workspace number 10

# --- Session ---
bindsym $mod+l              exec ${HOME}/.local/bin/swaylock-toasters
bindsym $mod+Shift+l        exec ${HOME}/.local/bin/toggle-autolock.sh
bindsym $mod+Shift+comma    reload
bindsym $mod+Shift+m        restart
bindsym $mod+Shift+period   exec swaymsg exit

# --- Screenshots ---
bindsym Print           exec flameshot gui
bindsym Ctrl+Print      exec grimshot copy screen
bindsym $mod+Print      exec grimshot copy window

# --- Brightness ---
bindsym XF86MonBrightnessUp   exec brightnessctl set 10%+
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# --- Volume ---
bindsym XF86AudioRaiseVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume  exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute         exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym $mod+F10              exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym $mod+F9               exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym $mod+F8               exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
