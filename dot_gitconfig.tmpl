[advice]
	detachedHead = false
[alias]
	amend = commit --amend --no-edit
[init]
	defaultBranch = main
[pull]
	rebase = true
[user]
	email = {{ .email | quote }}
	name = {{ .name | quote }}
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
