{{- $sourceDir := .chezmoi.sourceDir -}}
{{- $gobinDir := joinPath $sourceDir "gobin" -}}
{{- $rawMainFiles := output "find" $gobinDir "-mindepth" "2" "-maxdepth" "2" "-type" "f" "-name" "main.go" | trim -}}
#!/bin/bash
set -euo pipefail

if ! command -v go >/dev/null 2>&1; then
  echo "go not found; skipping local Go binary builds" >&2
  exit 0
fi

export CGO_ENABLED=0

{{- if $rawMainFiles }}
{{- range $main := splitList "\n" $rawMainFiles }}
{{- $name := base (dir $main) }}
# {{ $name }}: {{ include (printf "gobin/%s/main.go" $name) | sha256sum }}
(
  cd "{{ joinPath $sourceDir "gobin" $name }}"
  rm -f "$HOME/.local/bin/{{ $name }}"
  go build -o "$HOME/.local/bin/{{ $name }}"
)
{{- end }}
{{- end }}
